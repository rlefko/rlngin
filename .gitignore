tools/spsa/__pycache__/

# Live SPSA run artifacts. The driver continuously writes these files
# while tuning, which would otherwise show up as dirty tracked files and
# block the auto-apply sidecar's `git pull --rebase`. The final snapshot
# ships in the apply-values commit via `git add -f`.
tuning/spsa/history.csv
tuning/spsa/theta.json
tuning/spsa/live.json
tuning/spsa/run.log
tuning/spsa/auto-apply.log

# Texel run artifacts: large self-play PGN, the labeled corpus, the
# per-stage logs, and the archived final checkpoint. The compiled-in
# defaults in src/eval_params.cpp are what ship in the apply commit.
tuning/texel/games.pgn
tuning/texel/positions.epd
tuning/texel/selfplay.log
tuning/texel/extract.log
tuning/texel/tune.log
tuning/texel/checkpoint.txt
tuning/texel/pipeline.log
tuning/texel/pipeline.pid

# Live tuner checkpoint files. tools/tune.cpp rewrites these between
# passes; only the compiled-in defaults in src/eval_params.cpp ship.
tuning/checkpoint.txt
tuning/checkpoint_bestval.txt
